# ─────────────────────────────────────────────────────────────────
# Gov Docket Extractor — Environment Variables
# Copy this file to .env and fill in your actual keys.
# ─────────────────────────────────────────────────────────────────

# Required for Claude models (DOM-Chunking engine via Anthropic SDK)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for OpenRouter models (Llama, Gemini, Claude via proxy, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required for Groq models (fast open-source inference)
GROQ_API_KEY=your_groq_api_key_here

# Optional — Google Gemini direct API
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — xAI / Grok models
XAI_API_KEY=your_xai_api_key_here

# Optional — OpenAI models
OPENAI_API_KEY=your_openai_api_key_here
